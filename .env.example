# .env.example

# -------------
# Source Configuration
# -------------
SOURCE_PROVIDER=github
# Your GitHub Personal Access Token (requires repo and read:org scope)
SOURCE_TOKEN=ghp_...
# Your GitHub username
SOURCE_USER=isyuricunha

# -------------
# Destination Configuration
# -------------
DEST_PROVIDER=gitlab
# Your GitLab Access Token (requires api scope)
DEST_TOKEN=glpat-...
# Your GitLab destination username
DEST_USER=isyuricunha
# Leave empty for gitlab.com. If you are using a self-hosted instance, fill this:
DEST_URL=

# -------------
# Mirroring Rules
# -------------
# Filters which repositories to fetch from the source. all | public | private
REPO_VISIBILITY=all
# Comma-separated list of repository names to include specifically (e.g., repo1,repo2). Empty = Sync ALL.
REPO_INCLUDE=
# Comma-separated list of repository names to ignore
REPO_EXCLUDE=

# -------------
# Schedule
# -------------
# Synchronization interval. If left empty, it will run once and exit.
# Ex: 6h, 1h, 30m, 10s
SYNC_INTERVAL=6h
